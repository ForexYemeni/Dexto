# ============================================
# Dexto - Crypto Mining Investment Platform
# Environment Variables Template
# ============================================

# Database (SQLite for development, PostgreSQL/MySQL for production)
# For SQLite: DATABASE_URL="file:./dev.db"
# For PostgreSQL: DATABASE_URL="postgresql://user:password@localhost:5432/dexto"
# For MySQL: DATABASE_URL="mysql://user:password@localhost:3306/dexto"
DATABASE_URL="file:./dev.db"

# JWT Secret (CHANGE THIS in production - use a strong random string)
# Generate one: openssl rand -base64 64
JWT_SECRET="change-this-to-a-secure-random-key-in-production-min-32-chars"

# Node Environment
NODE_ENV="development"

# Socket.io Service Port (for mini-service)
SOCKET_PORT=3003

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# 1. Change JWT_SECRET to a strong random string
# 2. Use PostgreSQL/MySQL instead of SQLite
# 3. Set NODE_ENV=production
# 4. Change default admin credentials (login → Settings → Admin Account)
# 5. Configure proper USDT wallet addresses for each network
# 6. Set up proper email service for notifications (optional)
# 7. Enable HTTPS (automatic on Vercel)
